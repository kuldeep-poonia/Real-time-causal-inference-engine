# Copy to .env and fill in values before running docker-compose up.

# ── REQUIRED for production ──────────────────────────────────────────────────
# Strong random string: openssl rand -hex 32
ABSIA_API_KEY=

# ── Optional: GitHub integration (for /explore context) ────────────────────
GITHUB_TOKEN=

# ── Optional: Prometheus integration ────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_QUERY=rate(container_cpu_usage_seconds_total[1m])

# ── Pipeline tuning ──────────────────────────────────────────────────────────
ABSIA_SEED=42
ABSIA_LOG_LEVEL=info
ABSIA_MAX_BODY_BYTES=1048576

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Requests per second per remote IP across pipeline endpoints (0 = disabled).
ABSIA_RATE_LIMIT_RPS=10
# Burst allowance above the sustained rate.
ABSIA_RATE_LIMIT_BURST=20

# ── HTTP timeouts ────────────────────────────────────────────────────────────
ABSIA_READ_TIMEOUT_SECONDS=5
ABSIA_WRITE_TIMEOUT_SECONDS=30
ABSIA_IDLE_TIMEOUT_SECONDS=120
